APP_NAME=AIPedia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aipedia
DB_USERNAME=root
DB_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Comma-separated provider IDs. The order is the fallback order after the active provider.
WEBCHAT_DOCS_APP_ID=aipedia
WEBCHAT_DOCS_FUZZY_ENABLED=true
WEBCHAT_DOCS_TOP_K=5
WEBCHAT_LLM_PROVIDERS=OPENROUTER
# Provider used first by the failover strategy. Leave empty only when another strategy chooses it.
WEBCHAT_LLM_ACTIVE_PROVIDER=
# failover = try the next provider after a transient error; switch = active only; round_robin = rotate.
WEBCHAT_LLM_STRATEGY=failover
# Maximum attempts across all providers for one model request.
WEBCHAT_LLM_TOTAL_ATTEMPT_BUDGET=4
# Provider circuit breaker: open after this many failures, then retry after cooldown seconds.
WEBCHAT_LLM_CIRCUIT_FAILURE_THRESHOLD=3
WEBCHAT_LLM_CIRCUIT_COOLDOWN_SEC=60
# HTTP statuses that may move the request to the next provider. 413 is request-too-large/token limit.
WEBCHAT_LLM_RETRY_STATUSES=408,409,413,425,429,500,502,503,504
# Shared defaults; provider-specific WEBCHAT_LLM_{ID}_* values below override them.
WEBCHAT_LLM_CONTEXT_WINDOW=131072
WEBCHAT_LLM_MAX_OUTPUT_TOKENS=4096
# Example provider. Copy the block for each ID in WEBCHAT_LLM_PROVIDERS.
WEBCHAT_LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Secret key: set this only in web/.env or your secret manager, never in git.
WEBCHAT_LLM_OPENROUTER_API_KEY=
WEBCHAT_LLM_OPENROUTER_MODEL=cohere/north-mini-code:free
WEBCHAT_LLM_OPENROUTER_API=chat
WEBCHAT_LLM_OPENROUTER_CONTEXT_WINDOW=131072
WEBCHAT_LLM_OPENROUTER_MAX_OUTPUT_TOKENS=4096
WEBCHAT_LLM_OPENROUTER_MAX_INPUT_TOKENS=12000
WEBCHAT_LLM_OPENROUTER_TIMEOUT_SEC=60
WEBCHAT_LLM_OPENROUTER_MAX_ATTEMPTS=1
WEBCHAT_LLM_OPENROUTER_WEIGHT=1
WEBCHAT_LLM_OPENROUTER_ENABLED=true
# true returns a local stub response; false sends requests to the configured provider.
WEBCHAT_LLM_STUB=true
WEBCHAT_PHASE=2
WEBCHAT_MAX_TOOL_ROUNDS=8
WEBCHAT_LLM_TIMEOUT_SEC=60
WEBCHAT_CONTEXT_COMPACTION_ENABLED=true
WEBCHAT_CONTEXT_MAX_INPUT_TOKENS=12000
WEBCHAT_CONTEXT_RESERVE_TOKENS=3000
WEBCHAT_CONTEXT_RECENT_TURNS=4
WEBCHAT_CONTEXT_SUMMARY_MAX_CHARS=12000
WEBCHAT_TURN_JOB_TIMEOUT_SEC=300
WEBCHAT_TURN_RATE_LIMIT_PER_MIN=10
WEBCHAT_SPEAK_FLOOR_TTL_SEC=600
WEBCHAT_CONVERSATION_IDLE_TTL_DAYS=7
