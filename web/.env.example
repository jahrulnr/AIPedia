APP_NAME=AIPedia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aipedia
DB_USERNAME=root
DB_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Comma-separated provider IDs. The order is the fallback order after the active provider.
WEBCHAT_DOCS_APP_ID=aipedia
WEBCHAT_LLM_PROVIDERS=OPENROUTER
# Provider used first by the failover strategy. Leave empty only when another strategy chooses it.
WEBCHAT_LLM_ACTIVE_PROVIDER=
# Example provider. Copy the three dynamic values for each ID in WEBCHAT_LLM_PROVIDERS.
WEBCHAT_LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Secret key: set this only in web/.env or your secret manager, never in git.
WEBCHAT_LLM_OPENROUTER_API_KEY=
WEBCHAT_LLM_OPENROUTER_MODEL=cohere/north-mini-code:free
